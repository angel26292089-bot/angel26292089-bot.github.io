  { name: "雙氧 6%", price: 150, unit: "瓶" },
  { name: "雙氧 9%", price: 150, unit: "瓶" },
  { name: "雙氧 12%", price: 150, unit: "瓶" },
];

const quantities = {};

function renderProducts() {
  const grid = document.getElementById('productGrid');
  let html = '';
  let lastCat = '';
  products.forEach((p, i) => {
    if (p.cat && p.cat !== lastCat) {
      html += `<span class="cat-label">${p.cat}</span>`;
      lastCat = p.cat;
    }
    const qty = quantities[i] || 0;
    html += `
      <div class="product-row ${qty > 0 ? 'selected' : ''}" id="row-${i}" onclick="toggleRow(${i})">
        <div class="product-name">${p.name}</div>
        <div class="product-price">${p.price}<span>元/${p.unit}</span></div>
        <div class="qty-control" onclick="event.stopPropagation()">
          <button class="qty-btn" onclick="changeQty(${i}, -1)">−</button>
          <span class="qty-num">${qty}</span>
          <button class="qty-btn" onclick="changeQty(${i}, 1)">＋</button>
        </div>
      </div>`;
  });
  grid.innerHTML = html;
}

function toggleRow(i) {
  quantities[i] = (!quantities[i] || quantities[i] === 0) ? 1 : 0;
  renderProducts();
  updateSummary();
}

function changeQty(i, delta) {
  quantities[i] = Math.max(0, (quantities[i] || 0) + delta);
  renderProducts();
  updateSummary();
}

function updateSummary() {
  const items = products.map((p, i) => ({ ...p, qty: quantities[i] || 0 })).filter(p => p.qty > 0);
  const summary = document.getElementById('orderSummary');
  if (items.length === 0) { summary.classList.remove('visible'); return; }
  summary.classList.add('visible');
  let total = 0;
  let html = '';
  items.forEach(p => {
    const sub = p.price * p.qty;
    total += sub;
    html += `<div class="summary-item"><span>${p.name} × ${p.qty}</span><span>${sub.toLocaleString()} 元</span></div>`;
  });
  document.getElementById('summaryItems').innerHTML = html;
  document.getElementById('summaryTotal').innerHTML = `<span class="summary-total-label">合計金額</span><span>${total.toLocaleString()} 元</span>`;
}

async function submitOrder() {
  const name = document.getElementById('inputName').value.trim();
  const phone = document.getElementById('inputPhone').value.trim();
  if (!name || !phone) { alert('請填寫姓名與電話'); return; }
  const items = products.map((p, i) => ({ ...p, qty: quantities[i] || 0 })).filter(p => p.qty > 0);
  if (items.length === 0) { alert('請至少選擇一項商品'); return; }
  const lineId = document.getElementById('inputLine').value.trim();
  const note = document.getElementById('inputNote').value.trim();
  let total = 0;
  let orderLines = '';
  items.forEach(p => {
    const sub = p.price * p.qty;
    total += sub;
    orderLines += `${p.name} × ${p.qty}　${sub.toLocaleString()} 元\n`;
  });
  const btn = document.getElementById('submitBtn');
  btn.disabled = true;
  btn.textContent = '傳送中…';
  try {
    await emailjs.send('service_k2vg3lyw', 'template_lylqqg7', {
      customer_name: name,
      customer_phone: phone,
      customer_line: lineId || '未填寫',
      order_items: orderLines,
      order_total: total.toLocaleString() + ' 元',
      note: note || '無',
    });
    const msg = `<strong>${name}</strong> 您好，<br><br>您的 TKO 系列訂單已成功送出！<br><br>我們將盡快與您確認訂單內容，請保持電話暢通。`;
    document.getElementById('successMsg').innerHTML = msg;
    document.getElementById('successOverlay').classList.add('show');
  } catch (err) {
    alert('訂單傳送失敗，請稍後再試或直接來電聯繫。');
  } finally {
    btn.disabled = false;
    btn.textContent = '送　出　訂　單';
  }
}

function closeSuccess() {
  document.getElementById('successOverlay').classList.remove('show');
}

renderProducts();
</script>
