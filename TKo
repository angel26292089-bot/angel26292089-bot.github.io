<style>
  :root {
    --ink: #1a1208;
    --paper: #f7f3ec;
    --red: #8b2e1a;
    --gold: #b8923a;
    --muted: #7a6e60;
    --border: #d4c9b8;
    --hover: #fdf8f0;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    background: var(--paper);
    color: var(--ink);
    font-family: 'Noto Serif TC', serif;
    min-height: 100vh;
    background-image:
      radial-gradient(ellipse at 20% 0%, rgba(200,169,126,0.12) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 100%, rgba(139,46,26,0.07) 0%, transparent 60%);
  }
  header {
    text-align: center;
    padding: 52px 24px 36px;
    border-bottom: 1px solid var(--border);
  }
  header::before {
    content: '';
    display: block;
    width: 1px; height: 40px;
    background: var(--gold);
    margin: 0 auto 20px;
  }
  .shop-name {
    font-family: 'Shippori Mincho', serif;
    font-size: clamp(26px, 5vw, 42px);
    font-weight: 600;
    letter-spacing: 0.25em;
    color: var(--ink);
  }
  .shop-sub {
    font-size: 12px;
    letter-spacing: 0.4em;
    color: var(--muted);
    margin-top: 10px;
    text-transform: uppercase;
  }
  .shop-divider {
    display: flex; align-items: center; justify-content: center;
    gap: 14px; margin: 18px auto 0; max-width: 300px;
  }
  .shop-divider span { flex: 1; height: 1px; background: var(--border); }
  .shop-divider i { color: var(--gold); font-size: 10px; }
  main { max-width: 760px; margin: 0 auto; padding: 40px 20px 80px; }
  .section-title {
    font-family: 'Shippori Mincho', serif;
    font-size: 13px;
    letter-spacing: 0.35em;
    color: var(--muted);
    text-align: center;
    margin-bottom: 28px;
  }
  .section-title::after {
    content: '';
    display: block;
    width: 30px; height: 1px;
    background: var(--gold);
    margin: 10px auto 0;
  }
  .product-grid { display: grid; gap: 2px; margin-bottom: 40px; }
  .product-row {
    display: grid;
    grid-template-columns: 1fr 90px 130px;
    align-items: center;
    background: white;
    border: 1px solid var(--border);
    border-radius: 2px;
    padding: 14px 18px;
    cursor: pointer;
    transition: all 0.2s ease;
    position: relative;
    overflow: hidden;
  }
  .product-row::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
    background: var(--gold);
    transform: scaleY(0);
    transition: transform 0.2s ease;
    transform-origin: center;
  }
  .product-row:hover { background: var(--hover); }
  .product-row.selected { background: #fdf5e8; border-color: var(--gold); }
  .product-row.selected::before { transform: scaleY(1); }
  .product-name { font-size: 14px; letter-spacing: 0.05em; color: var(--ink); line-height: 1.5; }
  .product-price {
    font-family: 'DM Serif Display', serif;
    font-size: 15px;
    color: var(--gold);
    text-align: center;
  }
  .product-price span {
    font-family: 'Noto Serif TC', serif;
    font-size: 11px;
    color: var(--muted);
    margin-left: 2px;
  }
  .qty-control { display: flex; align-items: center; justify-content: flex-end; gap: 8px; }
  .qty-btn {
    width: 28px; height: 28px;
    border: 1px solid var(--border);
    background: white;
    color: var(--ink);
    font-size: 16px;
    cursor: pointer;
    border-radius: 2px;
    display: flex; align-items: center; justify-content: center;
    transition: all 0.15s;
    flex-shrink: 0;
    line-height: 1;
  }
  .qty-btn:hover { border-color: var(--gold); color: var(--gold); }
  .qty-num {
    font-family: 'DM Serif Display', serif;
    font-size: 16px;
    min-width: 20px;
    text-align: center;
    color: var(--ink);
  }
  .order-form {
    background: white;
    border: 1px solid var(--border);
    padding: 32px 28px;
    margin-bottom: 28px;
  }
  .form-row { margin-bottom: 20px; }
  .form-label {
    display: block;
    font-size: 12px;
    letter-spacing: 0.2em;
    color: var(--muted);
    margin-bottom: 8px;
  }
  .form-input {
    width: 100%;
    padding: 11px 14px;
    border: 1px solid var(--border);
    background: var(--paper);
    font-family: 'Noto Serif TC', serif;
    font-size: 14px;
    color: var(--ink);
    outline: none;
    transition: border-color 0.2s;
    border-radius: 2px;
  }
  .form-input:focus { border-color: var(--gold); background: white; }
  textarea.form-input { resize: vertical; min-height: 80px; }
  .order-summary {
    background: #fdf5e8;
    border: 1px solid var(--gold);
    padding: 24px 28px;
    margin-bottom: 28px;
    display: none;
  }
  .order-summary.visible { display: block; }
  .summary-title { font-size: 12px; letter-spacing: 0.3em; color: var(--muted); margin-bottom: 16px; }
  .summary-item {
    display: flex;
    justify-content: space-between;
    font-size: 13px;
    padding: 6px 0;
    border-bottom: 1px dashed var(--border);
    color: var(--ink);
  }
  .summary-total {
    display: flex;
    justify-content: space-between;
    font-family: 'DM Serif Display', serif;
    font-size: 20px;
    color: var(--red);
    margin-top: 14px;
    padding-top: 10px;
  }
  .summary-total-label {
    font-family: 'Noto Serif TC', serif;
    font-size: 13px;
    letter-spacing: 0.2em;
    color: var(--muted);
    align-self: flex-end;
    padding-bottom: 2px;
  }
  .submit-btn {
    width: 100%;
    padding: 18px;
    background: var(--ink);
    color: var(--paper);
    border: none;
    font-family: 'Shippori Mincho', serif;
    font-size: 15px;
    letter-spacing: 0.4em;
    cursor: pointer;
    transition: all 0.25s;
    position: relative;
    overflow: hidden;
  }
  .submit-btn::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 2px;
    background: var(--gold);
    transform: scaleX(0);
    transition: transform 0.3s ease;
  }
  .submit-btn:hover { background: #2d2418; }
  .submit-btn:hover::after { transform: scaleX(1); }
  .submit-btn:disabled { background: #ccc; cursor: not-allowed; }
  .success-overlay {
    display: none;
    position: fixed; inset: 0;
    background: rgba(26,18,8,0.85);
    z-index: 100;
    align-items: center; justify-content: center;
  }
  .success-overlay.show { display: flex; }
  .success-card {
    background: var(--paper);
    padding: 52px 48px;
    text-align: center;
    max-width: 400px; width: 90%;
    animation: fadeUp 0.4s ease;
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .success-icon { font-size: 36px; margin-bottom: 20px; display: block; }
  .success-title {
    font-family: 'Shippori Mincho', serif;
    font-size: 22px;
    letter-spacing: 0.3em;
    color: var(--ink);
    margin-bottom: 12px;
  }
  .success-msg { font-size: 13px; color: var(--muted); line-height: 1.9; letter-spacing: 0.05em; }
  .success-close {
    margin-top: 28px;
    padding: 12px 40px;
    background: var(--ink);
    color: var(--paper);
    border: none;
    font-family: 'Noto Serif TC', serif;
    font-size: 13px;
    letter-spacing: 0.25em;
    cursor: pointer;
  }
  .notice {
    text-align: center;
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 0.1em;
    line-height: 2;
    padding: 20px;
    border-top: 1px solid var(--border);
    margin-top: 20px;
  }
  .cat-label {
    font-size: 11px;
    letter-spacing: 0.3em;
    color: var(--muted);
    padding: 18px 18px 8px;
    display: block;
    text-transform: uppercase;
  }
  @media (max-width: 500px) {
    .product-row { grid-template-columns: 1fr 80px 110px; padding: 12px 12px; }
    .product-name { font-size: 13px; }
    .order-form { padding: 24px 18px; }
  }
</style>
</head>
<body>

<header>
  <div class="shop-name">髮染日式快染店</div>
  <div class="shop-sub">TKO Series · Order Form</div>
  <div class="shop-divider">
    <span></span><i>✦</i><span></span>
  </div>
</header>

<main>
  <p class="section-title">選擇商品 · 填寫資料 · 送出訂單</p>
  <div class="product-grid" id="productGrid"></div>

  <div class="order-summary" id="orderSummary">
    <div class="summary-title">訂單明細</div>
    <div id="summaryItems"></div>
    <div class="summary-total">
      <span class="summary-total-label">合計金額</span>
      <span id="summaryTotal">0 元</span>
    </div>
  </div>

  <div class="order-form">
    <p class="section-title" style="text-align:left;margin-bottom:22px;">聯絡資訊</p>
    <div class="form-row">
      <label class="form-label">姓名 *</label>
      <input class="form-input" id="inputName" type="text" placeholder="請輸入您的姓名">
    </div>
    <div class="form-row">
      <label class="form-label">電話 *</label>
      <input class="form-input" id="inputPhone" type="tel" placeholder="請輸入聯絡電話">
    </div>
    <div class="form-row">
      <label class="form-label">LINE ID</label>
      <input class="form-input" id="inputLine" type="text" placeholder="方便聯繫的 LINE ID（選填）">
    </div>
    <div class="form-row" style="margin-bottom:0">
      <label class="form-label">備註</label>
      <textarea class="form-input" id="inputNote" placeholder="如有特殊需求請填寫"></textarea>
    </div>
  </div>

  <button class="submit-btn" id="submitBtn" onclick="submitOrder()">送　出　訂　單</button>

  <div class="notice">
    ※ 訂單送出後，本店將於一個工作天內與您確認<br>
    ※ 價格如有變動，以實際報價為準
  </div>
</main>

<div class="success-overlay" id="successOverlay">
  <div class="success-card">
    <span class="success-icon">✦</span>
    <div class="success-title">訂單已送出</div>
    <div class="success-msg" id="successMsg"></div>
    <button class="success-close" onclick="closeSuccess()">確認</button>
  </div>
</div>

